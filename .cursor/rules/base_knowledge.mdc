## Common Patterns

### Feature Config
```typescript
import { defineFeature } from '@/lib/features/defineFeature'

export default defineFeature({
  id: '{slug}',
  name: '{Name}',
  description: '{Description}',
  ui: {
    icon: '{Icon}',
    path: '/dashboard/{slug}',
    component: '{Name}Page',
    category: '{category}',
    order: 100,
  },
  technical: {
    featureType: 'optional', // default | optional | experimental
    hasUI: true,
    hasConvex: true,
    hasTests: true,
    version: '1.0.0',
  },
  status: {
    state: 'stable', // development | beta | stable | deprecated
    isReady: true,
  },
  permissions: ['{slug}.view'],
})
```

### Convex Mutation
```typescript
export const createResource = mutation({
  args: { workspaceId: v.id('workspaces'), title: v.string() },
  handler: async (ctx, args) => {
    // 1. Permission check
    const { membership } = await requirePermission(
      ctx, args.workspaceId, 'resource.create'
    )
    // 2. Validation
    // 3. Business logic
    const id = await ctx.db.insert('resources', { ... })
    // 4. Audit log
    await logAuditEvent(ctx, { ... })
    return id
  }
})
```

### React Component
```typescript
'use client'
import { useQuery, useMutation } from 'convex/react'
import { api } from '@/convex/_generated/api'

export function ResourceList({ workspaceId }: Props) {
  const resources = useQuery(api.features.resources.queries.getResources, {
    workspaceId,
  })
  const createResource = useMutation(
    api.features.resources.mutations.createResource
  )
  // ...
}
```

## Commands

```bash
# Feature Management
pnpm run create:feature {slug}
pnpm run list:features
pnpm run edit:feature {slug}
pnpm run delete:feature {slug}
pnpm run sync:all

# Validation
pnpm run validate:all
pnpm run validate:features
pnpm run validate:permissions
pnpm run validate:audit

# Testing
pnpm test
pnpm test:coverage

# Development
pnpm dev
npx convex dev
```

