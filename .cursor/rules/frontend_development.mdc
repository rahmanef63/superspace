**Use shadcn/ui components:**
- Import from `@/frontend/shared/ui/`
- Don't create custom components that duplicate shadcn/ui functionality
- Customize via className props when needed

## State Management

**Use Zustand for client state:**

```typescript
import { create } from 'zustand'

interface ResourceStore {
  selectedId: string | null
  setSelected: (id: string | null) => void
}

export const useResourceStore = create<ResourceStore>((set) => ({
  selectedId: null,
  setSelected: (id) => set({ selectedId: id }),
}))
```

**Use React hooks for component state:**
```typescript
const [isOpen, setIsOpen] = useState(false)
const [searchQuery, setSearchQuery] = useState('')
```

## Form Handling

**Use react-hook-form with Zod:**

```typescript
import { useForm } from 'react-hook-form'
import { zodResolver } from '@hookform/resolvers/zod'
import { z } from 'zod'

const schema = z.object({
  title: z.string().min(3, 'Title must be at least 3 characters'),
  description: z.string().optional(),
})

type FormData = z.infer<typeof schema>

export function ResourceForm({ onSubmit }: Props) {
  const form = useForm<FormData>({
    resolver: zodResolver(schema),
  })

  return (
    <form onSubmit={form.handleSubmit(onSubmit)}>
      <input {...form.register('title')} />
      {form.formState.errors.title && (
        <p>{form.formState.errors.title.message}</p>
      )}
      <Button type="submit">Submit</Button>
    </form>
  )
}
```
