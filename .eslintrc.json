{
  "root": true,
  "extends": ["next/core-web-vitals"],
  "settings": {
    "next": {
      "rootDir": ["app/*/", "pages", "frontend", "src"]
    }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": ["error", ["app"]],
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@/frontend/shared",
            "message": "Import from a specific domain path under @/frontend/shared/* instead of root barrel."
          }
        ],
        "patterns": [
          {
            "group": [
              "@/frontend/features/*/config",
              "@/frontend/features/*/config.ts",
              "@/frontend/features/*/config/index",
              "@/frontend/features/*/config/index.ts",
              "frontend/features/*/config",
              "frontend/features/*/config.ts",
              "frontend/features/*/config/index",
              "frontend/features/*/config/index.ts"
            ],
            "message": "Do not import feature config directly. Use feature registry auto-discovery."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["frontend/shared/**/*"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "../../builder/**",
                  "../../settings/**",
                  "../../communications/**",
                  "../../ui/**",
                  "../../foundation/**"
                ],
                "message": "Import from other domains via facade only"
              }
            ]
          }
        ]
      }
    }
  ]
}
