# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/build_*.log
/build_errors.txt
/trace_theme.log
/tsc-*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
.env.local
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
tsc-output.txt

# clerk configuration (can include secrets)
/.clerk/

# claude code local settings (machine-specific)
.claude/settings.local.json

# local tooling/temp files (machine-specific and can contain sensitive data)
/.codex-tmp/
/test.json
/null

